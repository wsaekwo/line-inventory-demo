# LINE Developers Console > your Messaging API channel > "Messaging API" tab
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# LINE Developers Console > your channel > "LIFF" tab > add a LIFF app
# Endpoint URL should be: https://<your-deployed-domain>/register
NEXT_PUBLIC_LIFF_ID=

# PocketBase
# Bare origin only — e.g. https://your-host.com, NOT the dashboard URL
# (which ends in /_/). URL of your running PocketBase instance
# (self-hosted, Fly.io, PocketHost, etc.)
POCKETBASE_URL=
# Superuser credentials so the bot can read/write the "items" collection
# regardless of its API rules. Create one with:
#   ./pocketbase superuser create you@example.com yourpassword
POCKETBASE_ADMIN_EMAIL=
POCKETBASE_ADMIN_PASSWORD=

# Comma-separated LINE userIds of the owners who should receive weekly reports.
# Easiest way to get these: have each owner message the bot the word "id" —
# it replies with their LINE userId directly, no log-digging or LIFF needed.
OWNER_LINE_USER_IDS=

# Shared secret required (as an `x-cron-secret` header) to call
# /api/push-report. Set this before pointing a scheduler at that endpoint.
CRON_SECRET=
